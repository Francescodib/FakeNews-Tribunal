# Python artefacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environment — never include this in the image
.venv/
venv/
env/

# Secrets — never bake these into the image
.env
.env.*
!.env.example

# Development / editor artefacts
.git/
.gitignore
.github/
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Test artefacts
tests/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# Logs
logs/
*.log

# Docs
README.md
SPEC.md

# The web subfolder is built by its own Dockerfile — exclude it from the API image
web/

# Docker files themselves (not needed inside the container)
Dockerfile
docker-compose.yml
.dockerignore

# Temporary Claude files
tmpclaude*/
