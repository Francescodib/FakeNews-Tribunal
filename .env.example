# LLM Providers (set only the ones you use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Search
TAVILY_API_KEY=

# Database
DATABASE_URL=postgresql+asyncpg://tribunal:tribunal@localhost:5432/tribunal

# Auth
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Debate
MAX_DEBATE_ROUNDS=5
DEFAULT_PROVIDER=anthropic

# CORS (comma-separated list or JSON array)
CORS_ORIGINS=["http://localhost:3000"]

# Server
HOST=0.0.0.0
PORT=8000
ENV=development
