# ──────────────────────────────────────────────────────────────────────────────
# FakeNews Tribunal — environment variables template
#
# Usage:
#   cp .env.example .env
#   Edit .env with your real values — NEVER commit .env to version control.
#
# Variables marked [REQUIRED] have no safe default and must be set.
# Variables marked [optional] have a default defined in core/config.py;
# you only need to set them if you want to override the default.
# ──────────────────────────────────────────────────────────────────────────────


# ── PostgreSQL (used by both the db service and the api service) ──────────────

# Credentials for the postgres container
POSTGRES_USER=tribunal
POSTGRES_PASSWORD=changeme_strong_db_password   # [REQUIRED in production]
POSTGRES_DB=tribunal

# Full async SQLAlchemy URL.
# In Docker Compose the host is "db" (the service name); for local dev use "localhost".
DATABASE_URL=postgresql+asyncpg://tribunal:changeme_strong_db_password@db:5432/tribunal


# ── Authentication ────────────────────────────────────────────────────────────

# Secret used to sign JWT access tokens. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-this-with-output-of-secrets-token-hex-32   # [REQUIRED in production]

JWT_ALGORITHM=HS256

# Access token lifetime in minutes.
# 480 (8 h) is comfortable for long Ollama analyses in development.
# Set to 30 in production.
ACCESS_TOKEN_EXPIRE_MINUTES=30   # recommended: 30 in prod, 480 in dev

# Refresh token lifetime in days (stored hashed in DB; single-use rotation).
REFRESH_TOKEN_EXPIRE_DAYS=30


# ── LLM providers — set only the ones you intend to use ──────────────────────

# Default provider to use when the request does not specify one.
# Allowed values: anthropic | openai | gemini | ollama
DEFAULT_PROVIDER=anthropic

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...   # [REQUIRED if DEFAULT_PROVIDER=anthropic]

# OpenAI
OPENAI_API_KEY=sk-...          # [REQUIRED if DEFAULT_PROVIDER=openai]

# Google Gemini
GEMINI_API_KEY=AIza...         # [REQUIRED if DEFAULT_PROVIDER=gemini]

# Ollama (local, no key needed — just make sure the service is reachable)
# In Docker Compose, if Ollama runs on the host machine use host-gateway:
#   OLLAMA_BASE_URL=http://host.docker.internal:11434
# For a dedicated ollama container, use the container name as hostname.
OLLAMA_BASE_URL=http://localhost:11434


# ── Search (Tavily) ───────────────────────────────────────────────────────────

# Get a free key at https://tavily.com
TAVILY_API_KEY=tvly-...   # [REQUIRED for web-search features]


# ── Debate / analysis settings ────────────────────────────────────────────────

# Maximum number of researcher ↔ devil-advocate rounds before the judge rules.
MAX_DEBATE_ROUNDS=5

# Maximum claims allowed in a single batch submission.
MAX_BATCH_SIZE=10


# ── Webhooks ──────────────────────────────────────────────────────────────────

# Seconds to wait for the target endpoint to respond.
WEBHOOK_TIMEOUT_S=10

# How many times to retry a failed delivery (backoff: 5 / 30 / 300 s).
WEBHOOK_MAX_RETRIES=3


# ── CORS ─────────────────────────────────────────────────────────────────────
# JSON array of allowed origins. Must include every frontend origin that will
# call the API. Credentials are passed via Authorization header (not cookies),
# so allow_credentials=False is fine.
#
# Development (web container + local browser):
CORS_ORIGINS=["http://localhost:3000","http://web:3000"]
#
# Production example (replace with your real domain):
# CORS_ORIGINS=["https://tribunal.example.com"]


# ── Server ────────────────────────────────────────────────────────────────────

HOST=0.0.0.0
PORT=8000

# "development" enables dev-seed on startup (4 test users created automatically).
# Set to "production" in prod — seed is skipped and no test accounts are created.
ENV=development


# ── Web UI (Next.js) ──────────────────────────────────────────────────────────
# Public URL of the API as seen by the user's browser.
# In Docker Compose with both services on the same host this is localhost:8000.
# In production replace with your API's public URL (e.g. https://api.example.com).
NEXT_PUBLIC_API_URL=http://localhost:8000
